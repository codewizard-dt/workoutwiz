    classDef kg fill:#f0fdf4,stroke:#16a34a,color:#111;
    classDef safety fill:#fee2e2,stroke:#b91c1c,color:#111;
    classDef store fill:#fef3c7,stroke:#b45309,color:#111;
    classDef actor fill:#f3e8ff,stroke:#7c3aed,color:#111;

    class ROUTER router;
    class COACH,LOG,KG agent;
    class CLARIFY static;
    class RETRIEVAL,GEN kg;
    class SAFETY safety;
    class AUDIT store;
    class User actor;
