FROM python:3.11-slim
WORKDIR /app
# Heavy ML deps cached separately — only rebuilds when these change, not on every pyproject.toml edit
RUN pip install --no-cache-dir torch sentence-transformers langchain-huggingface
COPY pyproject.toml .
RUN pip install --no-cache-dir -e ".[dev]"
COPY docker-entrypoint.sh ./
RUN chmod +x docker-entrypoint.sh
CMD ["/bin/sh", "./docker-entrypoint.sh"]
