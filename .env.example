# ---------------------------------------------------------------------------
# Backend — FastAPI / SQLAlchemy / LangGraph
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workoutwiz
SECRET_KEY=changeme-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
COHERE_API_KEY=your-cohere-api-key-here
ROUTER_MODEL=claude-haiku-4-5
COACH_MODEL=claude-sonnet-4-6
GENERATOR_MODEL=claude-opus-4-8
LOGGER_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Neo4j — knowledge graph
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ---------------------------------------------------------------------------
# Embeddings — vector index for GraphRAG retrieval
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# Docker Compose — port overrides (optional; defaults shown)
# ---------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=80
DB_PORT=5433
