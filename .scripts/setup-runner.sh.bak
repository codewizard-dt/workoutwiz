#!/bin/bash
# Setup script for the GitHub Actions self-hosted runner on the VPS.
# Run as root on a fresh Ubuntu 24.04 droplet:
#
#   RUNNER_TOKEN=<token> REPO_URL=<repo_url> bash /tmp/setup-runner.sh
#
# Required env vars:
#   RUNNER_TOKEN  — single-use registration token from GitHub UI
#   REPO_URL      — e.g. https://github.com/codewizard-dt/workoutwiz
#
set -euo pipefail

: "${RUNNER_TOKEN:?RUNNER_TOKEN is required}"
: "${REPO_URL:?REPO_URL is required}"

RUNNER_VERSION="2.322.0"
RUNNER_DIR="/opt/actions-runner"
PROJECT_DIR="/opt/workoutwiz"
RUNNER_USER="runner"

# ---------------------------------------------------------------------------
# Install Docker
# ---------------------------------------------------------------------------
if ! command -v docker &>/dev/null; then
  echo "[setup] Installing Docker..."
  curl -fsSL https://get.docker.com | sh
  systemctl enable --now docker
else
  echo "[setup] Docker already installed."
fi

# ---------------------------------------------------------------------------
# Install GitHub CLI
# ---------------------------------------------------------------------------
if ! command -v gh &>/dev/null; then
  echo "[setup] Installing GitHub CLI..."
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] \
    https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null
  apt-get update -q && apt-get install -y gh
else
  echo "[setup] GitHub CLI already installed."
fi

# ---------------------------------------------------------------------------
# Create runner user
# ---------------------------------------------------------------------------
if ! id "$RUNNER_USER" &>/dev/null; then
  echo "[setup] Creating user '$RUNNER_USER'..."
  useradd -m -G docker "$RUNNER_USER"
else
  echo "[setup] User '$RUNNER_USER' already exists."
  usermod -aG docker "$RUNNER_USER"
fi

# ---------------------------------------------------------------------------
# Create project directory and set ownership
# ---------------------------------------------------------------------------
mkdir -p "$PROJECT_DIR"
chown -R "$RUNNER_USER:$RUNNER_USER" "$PROJECT_DIR"

# ---------------------------------------------------------------------------
# Install Actions runner
# ---------------------------------------------------------------------------
mkdir -p "$RUNNER_DIR"
chown -R "$RUNNER_USER:$RUNNER_USER" "$RUNNER_DIR"

if [ ! -f "$RUNNER_DIR/config.sh" ]; then
  echo "[setup] Downloading Actions runner v${RUNNER_VERSION}..."
  ARCH=$(uname -m)
  case "$ARCH" in
    x86_64) RUNNER_ARCH="x64" ;;
    aarch64) RUNNER_ARCH="arm64" ;;
    *) echo "Unsupported arch: $ARCH"; exit 1 ;;
  esac

  TARBALL="actions-runner-linux-${RUNNER_ARCH}-${RUNNER_VERSION}.tar.gz"
  curl -fsSL -o "/tmp/${TARBALL}" \
    "https://github.com/actions/runner/releases/download/v${RUNNER_VERSION}/${TARBALL}"
  tar xzf "/tmp/${TARBALL}" -C "$RUNNER_DIR"
  rm "/tmp/${TARBALL}"
fi

# ---------------------------------------------------------------------------
# Register the runner
# ---------------------------------------------------------------------------
echo "[setup] Registering runner with GitHub..."
sudo -u "$RUNNER_USER" "$RUNNER_DIR/config.sh" \
  --url "$REPO_URL" \
  --token "$RUNNER_TOKEN" \
  --name "workoutwiz-prod" \
  --labels "prod" \
  --work "$RUNNER_DIR/_work" \
  --unattended \
  --replace

# ---------------------------------------------------------------------------
# Install and start as a systemd service
# ---------------------------------------------------------------------------
echo "[setup] Installing runner as a systemd service..."
"$RUNNER_DIR/svc.sh" install "$RUNNER_USER"
"$RUNNER_DIR/svc.sh" start

echo ""
echo "======================================================"
echo "  Runner setup complete!"
echo "  Name:   workoutwiz-prod"
echo "  Label:  prod"
echo "  Dir:    $RUNNER_DIR"
echo ""
  echo "  Verify at: https://github.com/codewizard-dt/workoutwiz/settings/actions/runners"
echo "======================================================"
